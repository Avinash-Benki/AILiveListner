# =============================================================================
# AI Live Listener - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# Eden AI API key for cloud-based LLM analysis.
# Get your key at: https://www.edenai.co/
# If not set, the system falls back to local LM Studio.
EDEN_AI_API_KEY=

# -----------------------------------------------------------------------------
# Supabase Configuration (Optional)
# -----------------------------------------------------------------------------
# Required only if you want session persistence.
# Create a free project at: https://supabase.com/
# Then run the schema from supabase_schema.sql in the SQL editor.
SUPABASE_URL=
SUPABASE_KEY=
